# Database Configuration
DB_HOST=localhost               # Hostname for the MySQL database
DB_PORT=3306                    # Port number for the MySQL database
DB_NAME=opencharity             # Name of the MySQL database
DB_USER=opencharity_user        # Username for the MySQL database
DB_PASSWORD=opencharity_pass    # Password for the MySQL database user (required, set in .env)
DB_DIALECT=mysql                # Database dialect used by the ORM

# Redis Configuration
REDIS_HOST=localhost            # Hostname for the Redis server
REDIS_PORT=6379                 # Port number for the Redis server
REDIS_PASSWORD=redis_password   # Password for the Redis server (optional, set in .env if required)

# Application Settings
NODE_ENV=development            # Environment (development, production)
PORT=3000                       # Port number for the application to listen on
BASE_URL=http://localhost:3000  # Base URL for the application 

# Authentication & Security
SESSION_SECRET=session_secret   # Secret key for session management (required, set in .env)
SESSION_MAX_AGE=86400000        # Maximum age for sessions in milliseconds (default: 24 hours)
JWT_SECRET=jwt_secret_key       # Secret key for JWT authentication (required, set in .env)
JWT_EXPIRES_IN=24h              # Expiration time for JWT tokens (default: 24 hours)

# File Upload
UPLOAD_PATH=./public/uploads    # Directory path for storing uploaded files
MAX_UPLOAD_SIZE=5242880         # Maximum file upload size in bytes (default: 5 MB)

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000     # Time window for rate limiting in milliseconds (default: 15 minutes)
RATE_LIMIT_MAX_REQUESTS=100     # Maximum number of requests allowed within the rate limit window (default: 100)