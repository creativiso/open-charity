{
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "lint-staged": {
    "*.{js,ts}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "scripts": {
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:restart": "docker compose restart",
    "docker:logs": "docker compose logs -f",
    "docker:logs:mysql": "docker compose logs -f mysql",
    "docker:logs:redis": "docker compose logs -f redis",
    "docker:ps": "docker compose ps",
    "docker:clean": "docker compose down -v --remove-orphans",
    "docker:rebuild": "docker compose down && docker compose build --no-cache && docker compose up -d",
    "services:start": "npm run docker:up",
    "services:stop": "npm run docker:down",
    "services:restart": "npm run docker:restart",
    "services:status": "npm run docker:ps",
    "services:clean": "npm run docker:clean",
    "services:check": "node scripts/check-services.js",
    "dev": "nodemon server.js",
    "dev:debug": "nodemon --inspect server.js",
    "start": "node server.js",
    "build": "npm run build:admin",
    "build:admin": "cd admin-client && ng build --configuration production",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "test:unit": "jest --testPathPattern=unit",
    "test:integration": "jest --testPathPattern=integration",
    "lint": "eslint . --ext .js",
    "lint:fix": "eslint . --ext .js --fix",
    "format": "prettier --write \"**/*.{js,json,md}\"",
    "format:check": "prettier --check \"**/*.{js,json,md}\"",
    "db:create": "sequelize-cli db:create",
    "db:migrate": "sequelize-cli db:migrate",
    "db:migrate:undo": "sequelize-cli db:migrate:undo",
    "db:migrate:status": "sequelize-cli db:migrate:status",
    "db:seed": "sequelize-cli db:seed:all",
    "db:seed:undo": "sequelize-cli db:seed:undo:all",
    "db:reset": "npm run db:migrate:undo:all && npm run db:migrate && npm run db:seed",
    "db:drop": "sequelize-cli db:drop",
    "setup": "npm run services:start && npm run wait-for-db && npm run db:create && npm run db:migrate && npm run db:seed",
    "setup:clean": "npm run services:clean && npm run setup",
    "wait-for-db": "node scripts/wait-for-db.js",
    "postinstall": "husky install"
  },
  "devDependencies": {
    "@types/jest": "^29.5.11",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-node": "^11.1.0",
    "husky": "^8.0.3",
    "jest": "^29.7.0",
    "lint-staged": "^15.2.0",
    "prettier": "^3.1.1",
    "supertest": "^6.3.3"
  },
  "dependencies": {
    "chalk": "^5.6.2",
    "dotenv": "^17.3.1",
    "envalid": "^8.1.1",
    "mysql2": "^3.18.2",
    "redis": "^5.11.0"
  }
}
